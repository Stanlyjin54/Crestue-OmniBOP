<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kuafu.web.mapper.GeneralOrdersMapper">

    <sql id="general_orders_list_sql">
        SELECT
            id,
            order_no,
            user_id,
            op_id,
            order_type,
            order_status,
            pay_status,
            delivery_status,
            products_id,
            quality,
            total_amount,
            discount_amount,
            shipping_fee,
            actual_amount,
            payment_channel,
            payment_order_id,
            payment_time,
            payment_amount,
            shipping_method,
            shipping_address,
            shipping_company,
            tracking_number,
            tel,
            recipient,
            create_time,
            update_time,
            cancel_time,
            complete_time,
            deliver_time,
            refund_id,
            refund_no,
            refund_type,
            refund_amount,
            refund_reason,
            refund_status,
            remark,
            is_deleted,
            table_name,
            field_name
        FROM general_orders
    </sql>

    <resultMap id="BaseResultMap" type="com.kuafu.web.entity.GeneralOrders">
        <id column="id" property="id"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="op_id" property="opId"/>
        <result column="order_type" property="orderType"/>
        <result column="order_status" property="orderStatus"/>
        <result column="pay_status" property="payStatus"/>
        <result column="delivery_status" property="deliveryStatus"/>
        <result column="products_id" property="productsId"/>
        <result column="quality" property="quality"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="discount_amount" property="discountAmount"/>
        <result column="shipping_fee" property="shippingFee"/>
        <result column="actual_amount" property="actualAmount"/>
        <result column="payment_channel" property="paymentChannel"/>
        <result column="payment_order_id" property="paymentOrderId"/>
        <result column="payment_time" property="paymentTime"/>
        <result column="payment_amount" property="paymentAmount"/>
        <result column="shipping_method" property="shippingMethod"/>
        <result column="shipping_address" property="shippingAddress"/>
        <result column="shipping_company" property="shippingCompany"/>
        <result column="tracking_number" property="trackingNumber"/>
        <result column="tel" property="tel"/>
        <result column="recipient" property="recipient"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="cancel_time" property="cancelTime"/>
        <result column="complete_time" property="completeTime"/>
        <result column="deliver_time" property="deliverTime"/>
        <result column="refund_id" property="refundId"/>
        <result column="refund_no" property="refundNo"/>
        <result column="refund_type" property="refundType"/>
        <result column="refund_amount" property="refundAmount"/>
        <result column="refund_reason" property="refundReason"/>
        <result column="refund_status" property="refundStatus"/>
        <result column="remark" property="remark"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="table_name" property="tableName"/>
        <result column="field_name" property="fieldName"/>
    </resultMap>

    <select id="selectList" resultMap="BaseResultMap">
        <include refid="general_orders_list_sql"/>
    </select>

    <select id="selectPage" resultMap="BaseResultMap">
        <include refid="general_orders_list_sql"/>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        <include refid="general_orders_list_sql"/>
        WHERE id = #{id}
    </select>

</mapper>