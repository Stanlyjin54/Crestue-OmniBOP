{
  "name": "b2c-mall-frontend",
  "version": "1.0.0",
  "description": "B2C商城前端项目 - 基于Vue3 + TypeScript",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vue-tsc && vite build",
    "build:prod": "vue-tsc && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:components": "vitest src/test/components",
    "test:views": "vitest src/test/views",
    "test:utils": "vitest src/test/utils",
    "test:integration": "vitest src/test/integration"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.5.0",
    "dayjs": "^1.11.9",
    "element-plus": "^2.3.12",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.6",
    "qrcode": "^1.5.3",
    "vue": "^3.3.4",
    "vue-lazyload": "^3.0.0",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.3",
    "@types/jsdom": "^27.0.0",
    "@types/lodash-es": "^4.17.8",
    "@types/node": "^20.19.25",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.2",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.15",
    "eslint": "^8.47.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.28",
    "sass-embedded": "^1.93.3",
    "tailwindcss": "^3.3.3",
    "terser": "^5.44.1",
    "typescript": "^5.1.6",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-vue-components": "^0.25.2",
    "vite": "^6.0.0",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
